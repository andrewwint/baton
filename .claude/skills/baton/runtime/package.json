{
  "name": "@andrewwint/baton",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "description": "Manager-led development orchestrator runtime on the Claude Agent SDK",
  "license": "MIT",
  "bin": {
    "baton": "dist/orchestrator.js"
  },
  "scripts": {
    "build": "tsc",
    "orchestrate": "tsx --env-file-if-exists=.env src/orchestrator.ts",
    "start": "node --env-file-if-exists=.env dist/orchestrator.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.149"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
