{
  "name": "@andrewwint/baton",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Manager-led development orchestrator runtime on the Claude Agent SDK",
  "license": "MIT",
  "bin": {
    "baton": "dist/orchestrator.js"
  },
  "scripts": {
    "build": "tsc",
    "orchestrate": "tsx --env-file-if-exists=.env src/orchestrator.ts",
    "start": "node --env-file-if-exists=.env dist/orchestrator.js",
    "smoke": "npm run build && node scripts/smoke.mjs && node scripts/mcp-smoke.mjs && node scripts/conformance-smoke.mjs",
    "conformance": "node scripts/process-conformance.mjs",
    "validate-evals": "node scripts/validate-evals.mjs",
    "evals": "npm run build && node scripts/run-evals.mjs",
    "bench": "npm run build && node scripts/bench.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.149"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
