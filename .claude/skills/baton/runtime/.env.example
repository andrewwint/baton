# One of these must be set for the runtime to authenticate.
# The npm scripts (orchestrate, start) load this file via Node's
# `--env-file-if-exists=.env`; real environment variables take precedence.
# Running dist/orchestrator.js directly (or the `baton` bin) does NOT auto-load
# it — set the vars in your environment, or pass `--env-file-if-exists=.env`.
ANTHROPIC_API_KEY=

# Optional: override the SDK permission mode (default: acceptEdits)
# BATON_PERMISSION=acceptEdits

# Cost levers — the manager loop dominates cost. Defaults: sonnet, medium, 40 turns.
# BATON_MODEL=sonnet        # opus (hardest) | sonnet (default) | haiku (cheapest)
# BATON_EFFORT=medium       # low | medium | high | xhigh | max
# BATON_MAX_TURNS=40        # caps the agentic loop to bound worst-case cost
# Cheap read-only runs:  BATON_MODEL=haiku BATON_EFFORT=low
# Hardest implementation: BATON_MODEL=opus BATON_EFFORT=xhigh

# Run ledger is opt-in. The run summary and cost always print to stdout. Set this
# to ALSO persist run.json + summary.md under the directory (unset = no files
# written). Use ~/.baton/runs for global history, or an in-tree, gitignored path.
# BATON_LEDGER_DIR=/path/to/runs

# Optional semantic navigation via an MCP server (manager-only; off by default).
# Point this at a JSON file in the SDK's mcpServers shape; passed through to query().
# A ready-to-use Serena template ships next to this file: runtime/mcp.example.json
# (local `serena` binary, built-in `claude-code` context, current repo via
# --project-from-cwd, stdio, alwaysLoad to surface tools in headless runs).
#
# PREREQUISITE (opt-in only): you install the server yourself — a local `serena`
# on PATH, or `uvx --from git+https://github.com/oraios/serena serena ...`. The
# runtime never bundles it; nothing is required unless you set this var.
#
# TRUST + SCOPE: this launches the configured command locally with the runtime's
# privileges. Serena's claude-code context also includes shell-exec and file-edit
# tools — the manager already has Bash/Edit/Write, so that is redundant surface,
# not new power, but for navigation-only scope allowedTools instead of mcp__serena__*.
# BATON_MCP_CONFIG=/abs/path/to/baton/runtime/mcp.example.json

# Alternative providers (set the matching one instead of ANTHROPIC_API_KEY):
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_ANTHROPIC_AWS=1
# CLAUDE_CODE_USE_VERTEX=1
# CLAUDE_CODE_USE_FOUNDRY=1
